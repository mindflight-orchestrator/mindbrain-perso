# ══ PostgreSQL (used by test/run_all_tests.sh, psql, and libpq clients) ═══════
# Copy to ".env" at repo root. test/run_all_tests.sh sources it if present.
# On a host, PGHOST=pg_mindbrain_test is rewritten to 127.0.0.1 (see that script).
PGHOST=pg_mindbrain_test
PGPORT=5435
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres
PG_MAX_CONNECTIONS=100

# ══ Zig (this repo requires Zig 0.16.0) ═══════════════════════════════════════
# If your default `zig` is older, use a 0.16 binary in CI or your shell, e.g.:
#   export ZIG=zig-0.16
#   $ZIG build test
#ZIG=zig-0.16

# ══ Optional: PG-native document import worker ═══════════════════════════════
# Consumed by the Zig worker: ./zig-out/bin/mb-document-worker. The PostgreSQL extension
# itself does not read API keys or call remote LLMs. LLM variables vs SQL tests: see
# docs/mb-documents-llm-test-env.md
MB_DOCUMENTS_LLM_MODE=mock
MB_DOCUMENTS_LLM_BASE_URL=https://api.openai.com/v1
MB_DOCUMENTS_LLM_MODEL=gpt-4.1-mini
MB_DOCUMENTS_LLM_API_KEY=
MB_DOCUMENTS_LLM_TIMEOUT_MS=30000

# ══ Optional: Ghostcrab / MCP (NOT read by pg_mindbrain extension or import SQL) ═
# Use only if you run a separate app that documents these. Bulk import scripts
# (scripts/import_yago.sh, etc.) rely on standard PG* via psql, not GHOSTCRAB_*.
# GHOSTCRAB_MINDBRAIN_URL=http://127.0.0.1:8091
# GHOSTCRAB_BACKEND_ADDR=:8091
# GHOSTCRAB_SQLITE_PATH=data/ghostcrab.sqlite
# GHOSTCRAB_EMBEDDINGS_MODE=disabled
# MINDBRAIN_NATIVE_EXTENSIONS=sql-only
