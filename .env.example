
# ══ Zig (this repo requires Zig 0.16.0) ═══════════════════════════════════════
# If your default `zig` is older, use a 0.16 binary in CI or your shell, e.g.:
#   export ZIG=zig-0.16
#   $ZIG build test
#ZIG=zig-0.16

# ══ Optional: SQLite document LLM flows ══════════════════════════════════════
# Consumed by the standalone SQLite CLI document commands. Local unit tests and
# mock imports do not need remote LLM credentials. Live smokes are opt-in; see
# docs/dev/mb-documents-llm-test-env.md.
MB_DOCUMENTS_LLM_MODE=mock
# Select the live provider when MB_DOCUMENTS_LLM_MODE uses a real LLM.
# Supported values: openai, openrouter, anthropic.
MB_DOCUMENTS_LLM_PROVIDER=openai
# Generic OpenAI-compatible defaults. Provider-specific variables below take
# precedence for openrouter/anthropic once the resolver is enabled.
MB_DOCUMENTS_LLM_BASE_URL=https://api.openai.com/v1
MB_DOCUMENTS_LLM_MODEL=gpt-4.1-mini
MB_DOCUMENTS_LLM_API_KEY=
MB_DOCUMENTS_LLM_TIMEOUT_MS=30000

# ══ Optional: Ghostcrab / MCP ════════════════════════════════════════════════
# Use only if you run a separate app that documents these variables.
GHOSTCRAB_MINDBRAIN_URL=http://127.0.0.1:8091
GHOSTCRAB_BACKEND_ADDR=:8091
GHOSTCRAB_SQLITE_PATH=data/ghostcrab.sqlite
GHOSTCRAB_EMBEDDINGS_MODE=disabled
MINDBRAIN_NATIVE_EXTENSIONS=sql-only

# ══ Optional: OpenRouter live LLM provider ═══════════════════════════════════
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_CHAT_MODEL=qwen/qwen3-coder-next
OPENROUTER_CHAT_FALLBACK_MODEL=moonshotai/kimi-k2.5
OPENROUTER_CHAT_SMOKE_TEST=qwen/qwen3-coder:free

# ══ Optional: Anthropic native live LLM provider ═════════════════════════════
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VERSION=2023-06-01
